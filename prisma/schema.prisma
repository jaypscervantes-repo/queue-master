generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Gender {
  Male
  Female
}

enum Rank {
  A
  B
  C
  D
  E
}

enum PlayerStatus {
  Queued
  Playing
  Offline
  Paused
}

enum CourtStatus {
  Available
  Occupied
  Maintenance
}

enum MatchStatus {
  Playing
  Completed
  Cancelled
}

enum MatchCategory {
  MensDoubles
  WomensDoubles
  MixedDoubles
}

model Player {
  id                  String        @id @default(cuid())
  name                String
  gender              Gender
  rank                Rank
  preferredCategories Json          @default("[]")
  gamesPlayed         Int           @default(0)
  totalWins           Int           @default(0)
  status              PlayerStatus  @default(Offline)
  checkInTime         DateTime?
  waitingStartTime    DateTime?
  autoRequeue         Boolean       @default(true)
  active              Boolean       @default(true)
  username            String?       @unique
  pinHash             String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  queueEntry          QueueEntry?
  matchPlayers        MatchPlayer[]
  scheduleQueueEntries ScheduleQueueEntry[]

  @@map("players")
}

model QMaster {
  id        String     @id @default(cuid())
  name      String
  username  String     @unique
  pinHash   String
  email     String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  schedules Schedule[]

  @@map("qmasters")
}

model Schedule {
  id           String   @id @default(cuid())
  qmasterId    String
  qmaster      QMaster  @relation(fields: [qmasterId], references: [id], onDelete: Cascade)

  name          String?
  courtName     String
  courtContact  String
  contactPerson String
  startTime     DateTime
  endTime       DateTime
  cancelled    Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  queueEntries ScheduleQueueEntry[]
  matches      Match[]

  @@map("schedules")
  @@index([startTime])
  @@index([qmasterId])
  @@index([courtName, startTime])
}

model ScheduleQueueEntry {
  id         String   @id @default(cuid())
  scheduleId String
  playerId   String
  joinedAt   DateTime @default(now())

  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, playerId])
  @@map("schedule_queue_entries")
  @@index([scheduleId])
  @@index([playerId])
}

model QueueEntry {
  id         String   @id @default(cuid())
  playerId   String   @unique
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  position   Int      @default(0)
  queuedAt   DateTime @default(now())

  @@map("queue_entries")
  @@index([queuedAt])
}

model Court {
  id        String      @id @default(cuid())
  name      String      @unique
  status    CourtStatus @default(Available)
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  matches   Match[]

  @@map("courts")
}

model Match {
  id          String        @id @default(cuid())
  courtId     String?
  court       Court?        @relation(fields: [courtId], references: [id])
  scheduleId  String?
  schedule    Schedule?     @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  category    MatchCategory
  status      MatchStatus   @default(Playing)
  winningTeam Int?
  startTime   DateTime      @default(now())
  endTime     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  players     MatchPlayer[]

  @@map("matches")
  @@index([status])
  @@index([courtId])
  @@index([createdAt])
}

model Settings {
  id               Int       @id @default(1)
  sessionStart     DateTime?
  sessionEnd       DateTime?
  avgMatchDuration Int       @default(15)
  updatedAt        DateTime  @updatedAt

  @@map("settings")
}

model MatchPlayer {
  id       String @id @default(cuid())
  matchId  String
  playerId String
  team     Int

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@unique([matchId, playerId])
  @@map("match_players")
  @@index([matchId])
  @@index([playerId])
}
