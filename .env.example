# MySQL connection string
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/badminton_queue"

# App settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT=3000
NODE_ENV=development

# Player auth signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-with-32-random-bytes-base64"

# Required to create additional Admin accounts after the first one exists.
# First admin signup is open (no secret needed); after that, this secret must match.
ADMIN_SIGNUP_SECRET=""
